# Banco
DATABASE_URL="postgresql://escacev:escacev@localhost:5432/escacev"

# JWT
JWT_SECRET="troque-por-um-secret-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# Front-end — a rota do app onde o fluxo do Google aterrissa. O callback sempre
# redireciona para cá, com o resultado na query:
#   sucesso -> ?token=<jwt>
#   falha   -> ?error=auth_failed | no_email | not_authorized | api_error
# (a API manda a CHAVE, não a frase: o front decide o texto — evita expor mensagem
#  na barra de endereço e impede forjar um aviso falso num link)
# Se vazio, nada é redirecionado: o callback devolve o token como JSON e os erros
# saem no formato padrão { success, data, message } — útil para testar sem front.
# Com front rodando em dev: "http://localhost:5173/auth/callback"
FRONTEND_URL=""

# URL de login enviada no e-mail de convite (início do fluxo Google OAuth que
# vincula a conta ao membro). Sem front, aponte para a própria API (/auth/google);
# com front, aponte para a página de login do app.
APP_LOGIN_URL="http://localhost:3001/auth/google"

# Seed — Membro ADMIN_GERAL convidado (necessário para conseguir logar)
SEED_ADMIN_EMAIL="SEU_EMAIL_GOOGLE_AQUI"
SEED_ADMIN_NAME="Administrador Geral"

# Instituição (MVP single-institution)
INSTITUTION_ID="inst-escacev"
INSTITUTION_NAME="Ação Evangélica"

# E-mail (dev = Mailtrap, prod = SendGrid)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER="..."
SMTP_PASS="..."
FROM_EMAIL="noreply@escacev.app"

# App
PORT=3001
NODE_ENV=development

# ---------------------------------------------------------------------------
# PRODUÇÃO (VPS) — usado só pelo docker-compose.prod.yml
# ---------------------------------------------------------------------------
# Na VPS, copie este arquivo para `.env` NA RAIZ do projeto e preencha com os
# valores reais. O compose de produção aborta com mensagem clara se faltar
# alguma variável obrigatória — ele não sobe pela metade.
#
# Credenciais do Postgres. Em produção o banco não é exposto à internet (o
# serviço não publica portas), mas a senha ainda precisa ser forte: qualquer
# container na rede do compose a alcança.
#   POSTGRES_USER="escacev"
#   POSTGRES_PASSWORD="TROQUE-por-uma-senha-longa-e-aleatoria"
#   POSTGRES_DB="escacev"
#
# O host é `postgres` (nome do serviço na rede do compose), não localhost:
#   DATABASE_URL="postgresql://escacev:MESMA-SENHA-ACIMA@postgres:5432/escacev"
#
# Gere com: openssl rand -base64 48
#   JWT_SECRET="..."
#
# Front e API no MESMO domínio, com a API atrás do prefixo /api (o nginx remove
# o prefixo antes de repassar). Cadastre a callback abaixo no Google Console —
# em "URIs de redirecionamento autorizados" —, senão o login falha:
#   GOOGLE_CALLBACK_URL="https://escacev.com/api/auth/google/callback"
#   FRONTEND_URL="https://escacev.com/auth/callback"
#   APP_LOGIN_URL="https://escacev.com/login"
#
# O e-mail Google do PRIMEIRO administrador. O seed cria esse membro como
# convite pendente, e o callback do Google exige encontrá-lo para liberar o
# acesso — com o valor errado, o login devolve 403 sem mais explicação:
#   SEED_ADMIN_EMAIL="seu-email@gmail.com"
#   SEED_ADMIN_NAME="Seu Nome"
#
# E-mail de verdade (o Mailtrap é só de desenvolvimento — ele não entrega nada
# a ninguém). Sem isto, convite e notificação não saem, e convite é o ÚNICO
# caminho de entrada de um membro no sistema:
#   SMTP_HOST="smtp.sendgrid.net"
#   SMTP_PORT="587"
#   SMTP_USER="apikey"
#   SMTP_PASS="..."
#   FROM_EMAIL="noreply@escacev.com"
#
#   NODE_ENV=production
